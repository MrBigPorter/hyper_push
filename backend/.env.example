# ─── Database ──────────────────────────────
# SQLite (local dev)
DATABASE_URL="file:./dev.db"
# PostgreSQL (Supabase / production)
# DATABASE_URL="postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres"

# ─── JWT ───────────────────────────────────
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_EXPIRATION="7d"

# ─── App ───────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Email (optional) ────────────────────
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
