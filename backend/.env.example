# ─── Database ──────────────────────────────
# SQLite (local dev)
DATABASE_URL="file:./dev.db"
# PostgreSQL (Supabase / production)
# DATABASE_URL="postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres"
#
# Production PostgreSQL password (required by deploy/compose.prod.yml)
POSTGRES_PASSWORD="change-this-to-a-strong-password"
# Production MySQL root password for CodePush (required by deploy/compose.prod.yml)
MYSQL_ROOT_PASSWORD="change-this-to-a-strong-password"

# ─── JWT ───────────────────────────────────
# ⚠️  WARNING: JWT_SECRET is REQUIRED in production.
#    Leaving it unset will crash the application on startup.
#    Use a long, random string (e.g. openssl rand -hex 64).
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_EXPIRATION="7d"

# ─── TOTP / 2FA ────────────────────────────
# ⚠️  WARNING: TOTP_ENCRYPTION_KEY is REQUIRED in production.
#    This key encrypts all user 2FA (TOTP) secrets at rest using AES-256-GCM.
#    If this key changes, all existing 2FA secrets become undecryptable.
#    Use a long, random string (e.g. openssl rand -hex 32).
# TOTP_ENCRYPTION_KEY="change-me-to-a-random-secret-in-production"

# ─── App ───────────────────────────────────
PORT=3000
NODE_ENV=development
# PUBLIC_URL — 公网可访问的地址，用于 RN App 下载更新
# 生产环境设为 https://codepush.yourdomain.com
# PUBLIC_URL="https://codepush.yourdomain.com"

# ─── reCAPTCHA v3 ────────────────────────
# ⚠️  RECAPTCHA_SECRET_KEY is REQUIRED in production to enable bot detection.
#    Get your keys at https://www.google.com/recaptcha/admin
#    Google test key (always passes): 6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe
# RECAPTCHA_SECRET_KEY="your-recaptcha-secret-key"
RECAPTCHA_ENABLED=false
# RECAPTCHA_THRESHOLD=0.5

# ─── Grafana SSO ─────────────────────────
# ⚠️  GRAFANA_AUTH_SECRET is REQUIRED for Grafana SSO integration.
#    Must match the same value in infra-platform/.env
#    Generate with: openssl rand -hex 32
GRAFANA_AUTH_SECRET="change-me-to-a-random-secret"

# ─── Email (optional) ────────────────────
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
