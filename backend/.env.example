# ==========================================
# HyperPush — Environment Configuration
# ==========================================
# Quick start: Copy this file to .env, or run setup.sh for auto-generation
#   cp .env.example .env         # Local development
#   bash scripts/setup.sh         # Production deployment (auto-generates all secrets)
# ==========================================

# ─── Database ──────────────────────────────
# SQLite (local dev — no PostgreSQL needed)
DATABASE_URL="file:./dev.db"
#
# PostgreSQL (production — auto-filled by docker-entrypoint)
# DATABASE_URL="postgresql://hyperpush:password@db:5432/hyperpush"
#
# Production PostgreSQL password (auto-generated on container start if not set)
# POSTGRES_PASSWORD="your-password"
#
# Production MySQL root password for CodePush (auto-generated on container start if not set)
# MYSQL_ROOT_PASSWORD="your-password"

# ─── JWT ───────────────────────────────────
# ⚠️  Required in production! Auto-generated on container start if not set.
#    Recommended: openssl rand -hex 64
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_EXPIRATION="7d"

# ─── TOTP / 2FA ────────────────────────────
# ⚠️  AES-256-GCM key for encrypting user 2FA secrets.
#    Auto-generated on container start if not set. Changing it will break existing 2FA secrets.
#    Recommended: openssl rand -hex 16
# TOTP_ENCRYPTION_KEY="your-encryption-key"

# ─── App ───────────────────────────────────
PORT=3000
NODE_ENV=development
# PUBLIC_URL — Publicly accessible URL for RN App update downloads
# Auto-composed from CODEPUSH_DOMAIN on container start if not set
# PUBLIC_URL="https://codepush.yourdomain.com"

# ─── reCAPTCHA v3 ────────────────────────
# ⚠️  Optional. Auto-disabled if not set (RECAPTCHA_ENABLED=false)
#    Test key (always passes): 6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe
# RECAPTCHA_SECRET_KEY="your-recaptcha-secret-key"
RECAPTCHA_ENABLED=false

# ─── Grafana SSO (Optional) ────────────────────
# ⚠️  Optional. Grafana SSO is unavailable if not set.
#    Recommended: openssl rand -hex 32
# GRAFANA_AUTH_SECRET="your-grafana-secret"

# ─── GitHub Hot Fix (Optional) ─────────────────
# ⚠️  Optional. Hot Fix button hidden if not set.
# CODEPUSH_GITHUB_PAT="your-github-pat"
# CODEPUSH_GITHUB_OWNER="your-github-username"

# ─── SMTP (Optional) ───────────────────────────
# SMTP_HOST=""
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PASS=""
