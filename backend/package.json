{
  "name": "hyperpush-backend",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "bun --watch src/main.ts",
    "start:prod": "node dist/main",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check-types": "tsc --noEmit",
    "check:imports": "s=$(grep -rn 'import type' src/ --include='*.ts' | grep -E '(Service|Strategy|Jwt|Prisma)' | grep -vE 'scalar|OnModule|ExecutionContext|Response') && { echo \"$s\"; echo '❌ import type used for DI class — use \"import\" instead'; exit 1; }; s=$(grep -rn 'import type' src/ --include='*.resolver.ts' | grep -E '(Input|Dto|Model)' | grep -vE '^[^:]+/dto/|^[^:]+/models/') && { echo \"$s\"; echo '❌ import type used for GraphQL DTO in resolver — use \"import\" instead'; exit 1; }; echo '✅ All imports correct'",
    "validate:di": "bun scripts/validate-di.mts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/testing": "^11.1.24",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.40",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "husky": "^9.1.7"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs/apollo": "^13.4.2",
    "@nestjs/common": "^11.1.23",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.23",
    "@nestjs/graphql": "^13.4.2",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.23",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "graphql": "^16.14.0",
    "graphql-type-json": "^0.3.2",
    "nodemailer": "^8.0.8",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  }
}
