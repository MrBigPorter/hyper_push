generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // === 2FA (Google Authenticator / TOTP) ===
  totpSecret     String?   // encrypted TOTP secret (AES-256)
  totpEnabled    Boolean   @default(false)

  // === Ban / Block ===
  banned         Boolean   @default(false)
  bannedAt       DateTime?
  bannedReason   String?

  // === Login tracking ===
  lastLoginAt    DateTime?
  lastLoginIp    String?
  loginAttempts  Int       @default(0)
  lockoutUntil   DateTime?

  // Relations
  servers    Server[]
  apiKeys    ApiKey[]
  auditLogs  AuditLog[]
  loginLogs  LoginLog[]
}

model LoginLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  ip         String
  userAgent  String?
  success    Boolean  @default(true)
  failReason String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([ip, createdAt])
}

model Server {
  id        String   @id @default(cuid())
  name      String
  username  String
  apiKey    String
  isOnline  Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  active    Boolean  @default(true)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  expiresAt DateTime?
  lastUsed  DateTime?
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  detail    String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  ip        String?
  createdAt DateTime @default(now())
}
